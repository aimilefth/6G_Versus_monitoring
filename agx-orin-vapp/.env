COMPOSE_PROJECT_NAME=agx-orin-vapp

CLIENT_AGX_ORIN_VAPP_IMAGE=aimilefth/6gversus-monitoring:agx-orin-vapp

# Same server where Prometheus is running.
# Use host.docker.internal for same-machine Docker-to-host access,
# or use your public/server IP if that is how the other clients reach it.
CLIENT_AGX_ORIN_VAPP_PROMETHEUS_HOST=147.102.37.67
CLIENT_AGX_ORIN_VAPP_PROMETHEUS_PORT=9090

# Query once per second; each query re-reads a 3s window.
# This gives 1-2s overlap so old data can be retried safely.
CLIENT_AGX_ORIN_VAPP_SCRAPE_INTERVAL_S=2
CLIENT_AGX_ORIN_VAPP_FETCH_LOOKBACK_S=3
CLIENT_AGX_ORIN_VAPP_EMIT_DELAY_S=1
CLIENT_AGX_ORIN_VAPP_REQUEST_TIMEOUT_S=5

# Push calibrated output frequently.
CLIENT_AGX_ORIN_VAPP_PUSH_INTERVAL_S=1
CLIENT_AGX_ORIN_VAPP_MAX_RETRY_BATCHES=10
CLIENT_AGX_ORIN_VAPP_RAW_QUEUE_SIZE=1000
CLIENT_AGX_ORIN_VAPP_PROC_QUEUE_SIZE=1000
CLIENT_AGX_ORIN_VAPP_LOG_LEVEL=INFO

# Read the jtop telemetry as model input.
CLIENT_AGX_ORIN_VAPP_INPUT_SOURCE_REGEX=agx-orin-jtop-01
CLIENT_AGX_ORIN_VAPP_INPUT_SOURCE_LABEL=agx-orin-jtop-01
CLIENT_AGX_ORIN_VAPP_INPUT_METRIC_REGEX=agx_orin_.*

# Output identity in Prometheus.
CLIENT_AGX_ORIN_VAPP_SERVICE_LABEL=agx-orin-vapp-01
CLIENT_AGX_ORIN_VAPP_MODEL_LABEL=default
CLIENT_AGX_ORIN_VAPP_METRIC_CALIBRATED_POWER=agx_orin_vapp_calibrated_power_watts
CLIENT_AGX_ORIN_VAPP_OUTPUT_COMPONENT=calibrated_power
CLIENT_AGX_ORIN_VAPP_STATE_FILE=/data/agx-orin-vapp-state.json
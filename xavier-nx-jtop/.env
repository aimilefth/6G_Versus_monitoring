COMPOSE_PROJECT_NAME=xavier-nx-jtop

# Image name
CLIENT_XAVIER_NX_JTOP_IMAGE=aimilefth/6gversus-monitoring:xavier-nx-jtop

# Prometheus connection
CLIENT_XAVIER_NX_JTOP_PROMETHEUS_HOST=147.102.37.67
CLIENT_XAVIER_NX_JTOP_PROMETHEUS_PORT=9090

# Sampling / pushing
#
# jtop itself has an internal update cadence. Start with 0.5s or 1.0s,
# then reduce only if the host jtop service can keep up cleanly.
CLIENT_XAVIER_NX_JTOP_SCRAPE_INTERVAL_S=0.2
CLIENT_XAVIER_NX_JTOP_PUSH_INTERVAL_S=1
CLIENT_XAVIER_NX_JTOP_MAX_RETRY_BATCHES=10
CLIENT_XAVIER_NX_JTOP_LOG_LEVEL=INFO

# Label to identify this specific device in Grafana/Prometheus
CLIENT_XAVIER_NX_JTOP_SERVICE_LABEL=xavier-nx-jtop-01

# Optional: if /run/jtop.sock is group-restricted on the host:
#   export JTOP_GID="$(getent group jtop | awk -F: '{print $3}')"
# or put it here manually.
JTOP_GID=0

# Enable/disable whole metric groups.
# This makes it easy to turn off a slow collector without editing Python.
ENABLE_CPU_UTIL=true
ENABLE_CPU_FREQ=true
ENABLE_MEMORY_UTIL=true
ENABLE_GPU_UTIL=true
ENABLE_THERMAL=true
ENABLE_MEMORY_DETAILS=true
ENABLE_POWER=true
ENABLE_VOLTAGE=true
ENABLE_CURRENT=true

# Optional per-group minimum intervals.
# These let you collect cheap metrics often and expensive metrics less often.
# 0 means "every jtop sample".
CPU_UTIL_INTERVAL_S=0
CPU_FREQ_INTERVAL_S=0
MEMORY_UTIL_INTERVAL_S=0
GPU_UTIL_INTERVAL_S=0
THERMAL_INTERVAL_S=0
MEMORY_DETAILS_INTERVAL_S=0
POWER_INTERVAL_S=0
VOLTAGE_INTERVAL_S=0
CURRENT_INTERVAL_S=0

# Metric names.
# Prometheus-friendly names use underscores and unit suffixes.
METRIC_CPU_UTIL=xavier_nx_cpu_util_percent
METRIC_CPU_FREQ=xavier_nx_cpu_freq_khz
METRIC_MEMORY_UTIL=xavier_nx_memory_util_percent
METRIC_GPU_UTIL=xavier_nx_gpu_util_percent
METRIC_THERMAL=xavier_nx_thermal_celsius
METRIC_MEMORY_DETAILS=xavier_nx_memory_details_mb
METRIC_POWER_W=xavier_nx_power_watts
METRIC_VOLTAGE_V=xavier_nx_voltage_volts
METRIC_CURRENT_A=xavier_nx_current_amps

# If true, skip thermal sensors where jtop reports online=false or temp=-256.
SKIP_OFFLINE_THERMAL=true
COMPOSE_PROJECT_NAME=orin-nx

# Image name
CLIENT_ORIN_NX_IMAGE=aimilefth/6gversus-monitoring:orin-nx

# Prometheus Connection
# If running on a different machine than the server, put the Server IP here.
CLIENT_ORIN_NX_PROMETHEUS_HOST=147.102.37.67
CLIENT_ORIN_NX_PROMETHEUS_PORT=9090

# Tuning
CLIENT_ORIN_NX_SCRAPE_INTERVAL_S=1.0
CLIENT_ORIN_NX_PUSH_INTERVAL_S=4
CLIENT_ORIN_NX_MAX_RETRY_BATCHES=10
CLIENT_ORIN_NX_LOG_LEVEL=INFO

# Label to identify this specific device in Grafana
CLIENT_ORIN_NX_SERVICE_LABEL=orin-nx-01
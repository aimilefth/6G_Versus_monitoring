COMPOSE_PROJECT_NAME=agx-orin-jtop

# Image name
CLIENT_AGX_ORIN_JTOP_IMAGE=aimilefth/6gversus-monitoring:agx-orin-jtop

# Prometheus connection
CLIENT_AGX_ORIN_JTOP_PROMETHEUS_HOST=147.102.37.67
CLIENT_AGX_ORIN_JTOP_PROMETHEUS_PORT=9090

# Sampling / pushing
#
# jtop itself has an internal update cadence. Start with 0.5s or 1.0s,
# then reduce only if the host jtop service can keep up cleanly.
CLIENT_AGX_ORIN_JTOP_SCRAPE_INTERVAL_S=0.1
CLIENT_AGX_ORIN_JTOP_PUSH_INTERVAL_S=1
CLIENT_AGX_ORIN_JTOP_MAX_RETRY_BATCHES=10
CLIENT_AGX_ORIN_JTOP_LOG_LEVEL=INFO

# Label to identify this specific device in Grafana/Prometheus
CLIENT_AGX_ORIN_JTOP_SERVICE_LABEL=agx-orin-jtop-01

# Enable/disable whole metric groups.
# This makes it easy to turn off a slow collector without editing Python.
ENABLE_CPU_UTIL=true
ENABLE_CPU_FREQ=true
ENABLE_MEMORY_UTIL=true
ENABLE_GPU_UTIL=true
ENABLE_THERMAL=true
ENABLE_MEMORY_DETAILS=true
ENABLE_POWER=true
ENABLE_VOLTAGE=true
ENABLE_CURRENT=true

# Optional per-group minimum intervals.
# These let you collect cheap metrics often and expensive metrics less often.
# 0 means "every jtop sample".
CPU_UTIL_INTERVAL_S=0
CPU_FREQ_INTERVAL_S=0
MEMORY_UTIL_INTERVAL_S=0
GPU_UTIL_INTERVAL_S=0
THERMAL_INTERVAL_S=0
MEMORY_DETAILS_INTERVAL_S=0
POWER_INTERVAL_S=0
VOLTAGE_INTERVAL_S=0
CURRENT_INTERVAL_S=0

# Metric names.
# Prometheus-friendly names use underscores and unit suffixes.
METRIC_CPU_UTIL=agx_orin_cpu_util_percent
METRIC_CPU_FREQ=agx_orin_cpu_freq_mhz
METRIC_MEMORY_UTIL=agx_orin_memory_util_percent
METRIC_GPU_UTIL=agx_orin_gpu_util_percent
METRIC_THERMAL=agx_orin_thermal_celsius
METRIC_MEMORY_DETAILS=agx_orin_memory_details_mb
METRIC_POWER_W=agx_orin_power_watts
METRIC_VOLTAGE_V=agx_orin_voltage_volts
METRIC_CURRENT_A=agx_orin_current_amps

# If true, skip thermal sensors where jtop reports online=false or temp=-256.
SKIP_OFFLINE_THERMAL=true